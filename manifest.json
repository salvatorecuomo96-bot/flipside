{
  "manifest_version": 3,
  "name": "FlipSide",
  "version": "0.2.8",
  "description": "A skeptical mirror for web content. Surfaces the strongest credible counter-perspective when one exists.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://epistemic-companion-proxy.salvatoreducksamurai96.workers.dev/*",
    "https://api.groq.com/*",
    "https://api.deepseek.com/*",
    "https://api.openai.com/*",
    "https://openrouter.ai/*",
    "https://api.cerebras.ai/*",
    "https://api.sambanova.ai/*",
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.x.ai/*",
    "https://api.mistral.ai/*",
    "https://api.perplexity.ai/*",
    "https://api.together.xyz/*",
    "https://api.fireworks.ai/*",
    "https://api.openalex.org/*",
    "https://news.google.com/*",
    "https://en.wikipedia.org/*",
    "https://api.gdeltproject.org/*",
    "https://www.ebi.ac.uk/*",
    "https://export.arxiv.org/*",
    "https://www.courtlistener.com/*",
    "https://www.federalregister.gov/*",
    "https://clinicaltrials.gov/*",
    "https://search.worldbank.org/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "FlipSide — show counter-perspective",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/content/loader.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/content/main.js",
        "src/content/extractor.js",
        "src/content/ui/panel.js",
        "src/lib/api-client.js",
        "src/lib/prompt.js",
        "src/lib/sources.js"
      ],
      "matches": ["http://*/*", "https://*/*"]
    }
  ]
}
